# NEXUS configuration
# Copy this file to .env and update the values you want to use.

# ===== LLM Providers =====

# Groq is the recommended cloud provider for tool-calling demos.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# Ollama is the local fallback provider.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ===== MCP Servers =====

# Tavily enables the required external MCP server for live web search.
TAVILY_API_KEY=your_tavily_api_key_here

# Allowed roots for the official filesystem MCP server.
# Separate multiple paths with the OS path separator.
FILESYSTEM_ROOTS=.

# ===== Agent Runtime =====

EXECUTION_MODE=auto
MAX_ITERATIONS=10
MAX_CONTEXT_MESSAGES=20
LLM_TIMEOUT=30.0
TOOL_TIMEOUT=60.0
MCP_TIMEOUT=10.0
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1.0
DEBUG=false

# ===== Persistence and Logs =====

SESSION_DIR=./nexus_sessions
LOG_DIR=./logs

# ===== Local RAG =====

# Run `nexus build-rag --force` once before using the local documentation server.
RAG_SOURCE_DIR=./fixtures/rag_docs/langchain
RAG_DB_DIR=./rag/chroma_db
RAG_COLLECTION_NAME=langchain-docs
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_EMBEDDING_DIMENSION=256
